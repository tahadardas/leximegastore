{
  "info": {
    "_postman_id": "fd6d4f5d-b13f-43fd-9a83-e73671f8be6c",
    "name": "Lexi Admin Email Notifications",
    "description": "Admin notification settings and email diagnostics/test endpoints for Lexi API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Notification Settings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/notification-settings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "notification-settings"
          ]
        }
      }
    },
    {
      "name": "Save Notification Settings",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"management_emails\": [\n    \"admin1@example.com\",\n    \"admin2@example.com\"\n  ],\n  \"accounting_emails\": [\n    \"accounting@example.com\"\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/notification-settings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "notification-settings"
          ]
        }
      }
    },
    {
      "name": "Get Email Diagnostics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/email-diagnostics",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "email-diagnostics"
          ]
        }
      }
    },
    {
      "name": "Send Test Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"note\": \"manual_test_from_postman\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/email-diagnostics",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "email-diagnostics"
          ]
        }
      }
    },
    {
      "name": "Create Order (COD) - Trigger Emails",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {\n    \"name\": \"Customer Test\",\n    \"phone\": \"0999999999\",\n    \"email\": \"\"\n  },\n  \"address\": {\n    \"city_id\": {{city_id}},\n    \"street\": \"Damascus\",\n    \"notes\": \"\"\n  },\n  \"items\": [\n    {\n      \"product_id\": {{product_id}},\n      \"variation_id\": 0,\n      \"qty\": 1\n    }\n  ],\n  \"payment_method\": \"cod\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/checkout/create-order",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "checkout",
            "create-order"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://leximega.store"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "city_id",
      "value": "1"
    },
    {
      "key": "product_id",
      "value": "1"
    }
  ]
}

