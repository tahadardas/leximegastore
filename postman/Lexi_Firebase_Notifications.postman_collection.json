{
  "info": {
    "_postman_id": "7dc6b694-f4cf-4c20-8fc5-lexi-firebase-notifications",
    "name": "Lexi Firebase Notifications",
    "description": "Firebase notification management APIs for Lexi Mega Store",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "const token = json?.data?.access_token || json?.access_token || '';",
              "if (token) { pm.environment.set('access_token', token); }",
              "pm.test('Login status is 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Push - Register Device Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fcm_token\": \"{{fcm_token}}\",\n  \"device_id\": \"{{device_id}}\",\n  \"platform\": \"android\",\n  \"app_version\": \"1.0.0\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/notifications/register-token",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "notifications",
            "register-token"
          ]
        }
      }
    },
    {
      "name": "Admin - Get Firebase Settings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/notifications/firebase-settings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "notifications",
            "firebase-settings"
          ]
        }
      }
    },
    {
      "name": "Admin - Save Firebase Settings",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"enabled\": true,\n  \"server_key\": \"{{fcm_server_key}}\",\n  \"default_image_url\": \"{{notification_image_url}}\",\n  \"default_open_mode\": \"in_app\",\n  \"ttl_seconds\": 3600\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/notifications/firebase-settings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "notifications",
            "firebase-settings"
          ]
        }
      }
    },
    {
      "name": "Admin - Send Notification Campaign",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target\": \"broadcast\",\n  \"audience\": \"customer\",\n  \"title_ar\": \"عرض فلاش جديد\",\n  \"body_ar\": \"خصم قوي لفترة محدودة. اضغط لعرض التفاصيل.\",\n  \"type\": \"offer\",\n  \"open_mode\": \"deals\",\n  \"deep_link\": \"/deals\",\n  \"image_url\": \"{{notification_image_url}}\",\n  \"send_push\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/notifications/send",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "notifications",
            "send"
          ]
        }
      }
    },
    {
      "name": "Admin - Campaigns History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/wp-json/lexi/v1/admin/notifications/campaigns?page=1&per_page=20",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "wp-json",
            "lexi",
            "v1",
            "admin",
            "notifications",
            "campaigns"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "per_page",
              "value": "20"
            }
          ]
        }
      }
    }
  ],
