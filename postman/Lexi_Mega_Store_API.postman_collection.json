    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"password\": \"{{password}}\",\n  \"username\": \"{{register_username}}\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"phone\": \"0999999999\",\n  \"address_1\": \"Damascus\",\n  \"city\": \"Damascus\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/wp-json/lexi/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "wp-json",
                "lexi",
                "v1",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('register_email', `lexi_test_${ts}@example.com`);",
                  "pm.collectionVariables.set('register_username', `lexi_test_${ts}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let j = {};",
                  "try { j = pm.response.json(); } catch (e) {}",
                  "const data = j && j.data ? j.data : {};",
                  "const regEmail = pm.collectionVariables.get('register_email');",
                  "if (regEmail) pm.collectionVariables.set('email', regEmail);",
                  "if (data.access_token) pm.collectionVariables.set('access_token', data.access_token);",
                  "if (data.refresh_token) pm.collectionVariables.set('refresh_token', data.refresh_token);"
                ]
              }
            }
          ]
        },
